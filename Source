local function buildProfilesList()
    for _, child in ipairs(profilesList:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    local sortedNames = {}
    for name in pairs(profiles) do table.insert(sortedNames, name) end
    table.sort(sortedNames)

    if #sortedNames == 0 then
        local emptyLbl = Instance.new("TextLabel")
        emptyLbl.Size = UDim2.new(1,0,0,30); emptyLbl.BackgroundTransparency = 1
        emptyLbl.Text = "No saved configs yet."; emptyLbl.TextColor3 = Color3.fromRGB(70,80,120)
        emptyLbl.TextSize = 10; emptyLbl.Font = Enum.Font.Gotham; emptyLbl.ZIndex = 32
        emptyLbl.Parent = profilesList
        return
    end

    for i, name in ipairs(sortedNames) do
        local pRow = Instance.new("Frame")
        pRow.Size = UDim2.new(1,0,0,32); pRow.BackgroundColor3 = Color3.fromRGB(13,13,28)
        pRow.BorderSizePixel = 0; pRow.LayoutOrder = i; pRow.ZIndex = 32; pRow.Parent = profilesList
        Instance.new("UICorner", pRow).CornerRadius = UDim.new(0,6)

        local nameLbl = Instance.new("TextLabel")
        nameLbl.Size = UDim2.new(1,-80,1,0); nameLbl.Position = UDim2.new(0,8,0,0)
        nameLbl.BackgroundTransparency = 1; nameLbl.Text = name
        nameLbl.TextColor3 = Color3.fromRGB(180,200,255); nameLbl.TextSize = 10
        nameLbl.Font = Enum.Font.GothamMedium; nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.TextTruncate = Enum.TextTruncate.AtEnd; nameLbl.ZIndex = 33; nameLbl.Parent = pRow

        -- Load button
        local loadBtn = Instance.new("TextButton")
        loadBtn.Size = UDim2.new(0,32,0,22); loadBtn.Position = UDim2.new(1,-76,0.5,-11)
        loadBtn.BackgroundColor3 = Color3.fromRGB(15,50,100); loadBtn.BorderSizePixel = 0
        loadBtn.Text = "Load"; loadBtn.TextColor3 = Color3.fromRGB(100,180,255)
        loadBtn.TextSize = 9; loadBtn.Font = Enum.Font.GothamBold; loadBtn.ZIndex = 33
        loadBtn.Parent = pRow
        Instance.new("UICorner", loadBtn).CornerRadius = UDim.new(0,4)

        -- Delete button
        local delBtn = Instance.new("TextButton")
        delBtn.Size = UDim2.new(0,32,0,22); delBtn.Position = UDim2.new(1,-38,0.5,-11)
        delBtn.BackgroundColor3 = Color3.fromRGB(80,15,15); delBtn.BorderSizePixel = 0
        delBtn.Text = "Del"; delBtn.TextColor3 = Color3.fromRGB(255,100,100)
        delBtn.TextSize = 9; delBtn.Font = Enum.Font.GothamBold; delBtn.ZIndex = 33
        delBtn.Parent = pRow
        Instance.new("UICorner", delBtn).CornerRadius = UDim.new(0,4)

        local capName = name
        loadBtn.MouseButton1Click:Connect(function()
            local pdata = profiles[capName]
            if not pdata then return end
            for k,v in pairs(pdata) do
                if Cfg[k] ~= nil and typeof(v) == typeof(Cfg[k]) then
                    Cfg[k] = v
                    if sliderUpdaters[k] then sliderUpdaters[k](v) end
                    if toggleRefreshers[k] then toggleRefreshers[k](v) end
                end
            end
            -- refresh keybind btns
            for idx, kb in pairs(keybindBtns) do
                kb.btn.Text = Cfg[kb.cfgKey]
            end
            -- refresh GUI mode
            rectFrame.Visible = (Cfg.GUI_MODE == "rectangle")
            boxFrame.Visible  = (Cfg.GUI_MODE == "box")
            saveConfig()
            flashLoaderStatus('Loaded "'..capName..'"', Color3.fromRGB(100,255,100))
        end)

        delBtn.MouseButton1Click:Connect(function()
            profiles[capName] = nil
            saveProfiles()
            buildProfilesList()
            flashLoaderStatus('Deleted "'..capName..'"', Color3.fromRGB(255,160,80))
        end)
    end
end

