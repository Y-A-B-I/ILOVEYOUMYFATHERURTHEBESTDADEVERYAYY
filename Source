local function makeSlider(parent, label, key, minV, maxV, dec, order)
    local fmt=dec>0 and ("%."..dec.."f") or "%d"
    local row=Instance.new("Frame"); row.Size=UDim2.new(1,0,0,54)
    row.BackgroundColor3=Color3.fromRGB(13,13,28); row.BorderSizePixel=0
    row.LayoutOrder=order; row.ZIndex=22; row.Parent=parent
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,6)

    local nl=Instance.new("TextLabel"); nl.Size=UDim2.new(1,-70,0,13)
    nl.Position=UDim2.new(0,8,0,4); nl.BackgroundTransparency=1; nl.Text=label
    nl.TextColor3=Color3.fromRGB(180,200,255); nl.TextSize=10; nl.Font=Enum.Font.Gotham
    nl.TextXAlignment=Enum.TextXAlignment.Left; nl.ZIndex=23; nl.Parent=row

    local ib=Instance.new("TextBox"); ib.Size=UDim2.new(0,52,0,15)
    ib.Position=UDim2.new(1,-58,0,2); ib.BackgroundColor3=Color3.fromRGB(20,20,45)
    ib.BorderSizePixel=0; ib.Text=""; ib.TextColor3=Color3.fromRGB(70,225,255)
    ib.PlaceholderText="0"; ib.PlaceholderColor3=Color3.fromRGB(60,80,100)
    ib.TextSize=10; ib.Font=Enum.Font.GothamBold
    ib.TextXAlignment=Enum.TextXAlignment.Center; ib.ClearTextOnFocus=false
    ib.ZIndex=24; ib.Parent=row
    Instance.new("UICorner",ib).CornerRadius=UDim.new(0,4)
    local ibs=Instance.new("UIStroke"); ibs.Color=Color3.fromRGB(50,70,160); ibs.Thickness=1; ibs.Parent=ib

    local track=Instance.new("Frame"); track.Size=UDim2.new(1,-16,0,6)
    track.Position=UDim2.new(0,8,0,36); track.BackgroundColor3=Color3.fromRGB(25,25,55)
    track.BorderSizePixel=0; track.ZIndex=23; track.Parent=row
    Instance.new("UICorner",track).CornerRadius=UDim.new(0,3)

    local fill=Instance.new("Frame"); fill.Size=UDim2.new(0,0,1,0)
    fill.BackgroundColor3=Color3.fromRGB(70,150,255); fill.BorderSizePixel=0
    fill.ZIndex=24; fill.Parent=track
    Instance.new("UICorner",fill).CornerRadius=UDim.new(0,3)

    local thumb=Instance.new("Frame"); thumb.Size=UDim2.new(0,10,0,10)
    thumb.AnchorPoint=Vector2.new(0.5,0.5); thumb.BackgroundColor3=Color3.fromRGB(255,255,255)
    thumb.BorderSizePixel=0; thumb.ZIndex=25; thumb.Parent=track
    Instance.new("UICorner",thumb).CornerRadius=UDim.new(1,0)

    local function applyVal(v)
        v=math.clamp(v,minV,maxV)
        local m=10^dec; v=math.floor(v*m+0.5)/m
        local t=(v-minV)/(maxV-minV)
        fill.Size=UDim2.new(t,0,1,0); thumb.Position=UDim2.new(t,0,0.5,0)
        ib.Text=string.format(fmt,v); Cfg[key]=v
        ibs.Color=Color3.fromRGB(50,70,160); autoSave()
    end

    applyVal(Cfg[key]); sliderUpdaters[key]=applyVal

    local drag=false
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
            drag=true
            applyVal(minV+(maxV-minV)*math.clamp((inp.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1))
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if not drag then return end
        if inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch then
            applyVal(minV+(maxV-minV)*math.clamp((inp.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1))
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then drag=false end
    end)

    ib.Focused:Connect(function() ibs.Color=Color3.fromRGB(70,150,255) end)
    ib:GetPropertyChangedSignal("Text"):Connect(function()
        local cl=ib.Text:match("^%-?%d*%.?%d*") or ""
        if cl~=ib.Text then ib.Text=cl end
    end)
    ib.FocusLost:Connect(function()
        local n=tonumber(ib.Text)
        if n then applyVal(n)
        else ib.Text=string.format(fmt,Cfg[key]); ibs.Color=Color3.fromRGB(160,50,50)
            task.delay(1,function() ibs.Color=Color3.fromRGB(50,70,160) end)
        end
    end)
end

local function makeToggleRow(parent, label, key, order, onToggle)
    local row=Instance.new("Frame"); row.Size=UDim2.new(1,0,0,34)
    row.BackgroundColor3=Color3.fromRGB(13,13,28); row.BorderSizePixel=0
    row.LayoutOrder=order; row.ZIndex=22; row.Parent=parent
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,6)

    local lbl=Instance.new("TextLabel"); lbl.Size=UDim2.new(1,-60,1,0)
    lbl.Position=UDim2.new(0,10,0,0); lbl.BackgroundTransparency=1; lbl.Text=label
    lbl.TextColor3=Color3.fromRGB(180,200,255); lbl.TextSize=10; lbl.Font=Enum.Font.Gotham
    lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.ZIndex=23; lbl.Parent=row

    local pill=Instance.new("Frame"); pill.Size=UDim2.new(0,36,0,18)
    pill.Position=UDim2.new(1,-44,0.5,-9); pill.BackgroundColor3=Color3.fromRGB(40,40,80)
    pill.BorderSizePixel=0; pill.ZIndex=23; pill.Parent=row
    Instance.new("UICorner",pill).CornerRadius=UDim.new(1,0)
    local ps=Instance.new("UIStroke"); ps.Color=Color3.fromRGB(55,55,120); ps.Thickness=1; ps.Parent=pill

    local knob=Instance.new("Frame"); knob.Size=UDim2.new(0,12,0,12)
    knob.Position=UDim2.new(0,3,0.5,-6); knob.BackgroundColor3=Color3.fromRGB(140,140,180)
    knob.BorderSizePixel=0; knob.ZIndex=24; knob.Parent=pill
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)

    local pb=Instance.new("TextButton"); pb.Size=UDim2.new(1,0,1,0)
    pb.BackgroundTransparency=1; pb.Text=""; pb.ZIndex=25; pb.Parent=pill

    local function refresh(val)
        local t=getTheme()
        if val then
            TweenService:Create(pill,TweenInfo.new(0.18),{BackgroundColor3=Color3.fromRGB(20,60,160)}):Play()
            TweenService:Create(knob,TweenInfo.new(0.18),{Position=UDim2.new(0,21,0.5,-6),BackgroundColor3=t.accent}):Play()
            TweenService:Create(ps,TweenInfo.new(0.18),{Color=t.stroke}):Play()
        else
            TweenService:Create(pill,TweenInfo.new(0.18),{BackgroundColor3=Color3.fromRGB(40,40,80)}):Play()
            TweenService:Create(knob,TweenInfo.new(0.18),{Position=UDim2.new(0,3,0.5,-6),BackgroundColor3=Color3.fromRGB(140,140,180)}):Play()
            TweenService:Create(ps,TweenInfo.new(0.18),{Color=Color3.fromRGB(55,55,120)}):Play()
        end
    end

    refresh(Cfg[key]); toggleRefreshers[key]=refresh
    pb.MouseButton1Click:Connect(function()
        Cfg[key]=not Cfg[key]; refresh(Cfg[key]); autoSave()
        if onToggle then onToggle(Cfg[key]) end
    end)
    return refresh
end

local function makeKeybindRow(parent, label, idx, order)
