local function makeIcon(parent, assetId, fallback, size, pos, zi, color)
    local h = Instance.new("Frame")
    h.Size=size; h.Position=pos; h.BackgroundTransparency=1; h.ZIndex=zi; h.Parent=parent

    local img = Instance.new("ImageLabel")
    img.Size=UDim2.new(1,0,1,0); img.BackgroundTransparency=1; img.Image=assetId
    img.ImageColor3=color or Color3.new(1,1,1); img.ScaleType=Enum.ScaleType.Fit
    img.ZIndex=zi+1; img.Parent=h

    local fb = Instance.new("TextLabel")
    fb.Size=UDim2.new(1,0,1,0); fb.BackgroundTransparency=1; fb.Text=fallback
    fb.TextColor3=color or Color3.new(1,1,1); fb.TextScaled=true
    fb.Font=Enum.Font.GothamBold; fb.ZIndex=zi; fb.Visible=false; fb.Parent=h

    task.spawn(function()
        task.wait(3)
        if not img.IsLoaded or img.ImageRectSize==Vector2.new(0,0) then
            img.Visible=false; fb.Visible=true
        end
    end)
    img:GetPropertyChangedSignal("IsLoaded"):Connect(function()
        if img.IsLoaded then img.Visible=true; fb.Visible=false end
    end)
    return h, img, fb
end

