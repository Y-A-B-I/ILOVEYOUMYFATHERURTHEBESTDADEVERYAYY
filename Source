-- PANEL OPEN / CLOSE
-- =====================
local function getActiveFrame()
    return Cfg.GUI_MODE == "box" and boxFrame or rectFrame
end

local function setCfgOpen(val)
    cfgOpen = val; cfgPanel.Visible = val
    local af = getActiveFrame()
    local plusB = Cfg.GUI_MODE == "box" and boxPlusBtn or rectPlusBtn
    local plusS = Cfg.GUI_MODE == "box" and boxPlusStroke or rectPlusStroke
    plusB.Text = val and "−" or "+"
    plusB.TextColor3 = val and Color3.fromRGB(255,100,100) or Color3.fromRGB(120,180,255)
    plusS.Color = val and Color3.fromRGB(180,50,50) or Color3.fromRGB(60,80,180)
    plusB.BackgroundColor3 = val and Color3.fromRGB(40,10,10) or Color3.fromRGB(18,18,40)

    -- Reposition cfg panel relative to active toggle frame
    local fp = af.Position
    cfgPanel.Position = UDim2.new(fp.X.Scale, fp.X.Offset - 67, fp.Y.Scale, fp.Y.Offset - 430)
end

rectPlusBtn.MouseButton1Click:Connect(function() setCfgOpen(not cfgOpen) end)
boxPlusBtn.MouseButton1Click:Connect(function() setCfgOpen(not cfgOpen) end)
cfgCloseBtn.MouseButton1Click:Connect(function() setCfgOpen(false) end)

