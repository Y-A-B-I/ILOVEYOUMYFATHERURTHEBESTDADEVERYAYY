local function makeToggleRow(parent,label,key,order,onToggle)
    local row=Instance.new("Frame");row.Size=UDim2.new(1,0,0,34)
    row.BackgroundColor3=Color3.fromRGB(13,13,28);row.BorderSizePixel=0
    row.LayoutOrder=order;row.ZIndex=22;row.Parent=parent
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,6)
    local lbl=Instance.new("TextLabel");lbl.Size=UDim2.new(1,-60,1,0);lbl.Position=UDim2.new(0,10,0,0)
    lbl.BackgroundTransparency=1;lbl.Text=label;lbl.TextColor3=Color3.fromRGB(180,200,255)
    lbl.TextSize=10;lbl.Font=Enum.Font.Gotham;lbl.TextXAlignment=Enum.TextXAlignment.Left;lbl.ZIndex=23;lbl.Parent=row
    local pill=Instance.new("Frame");pill.Size=UDim2.new(0,36,0,18);pill.Position=UDim2.new(1,-44,0.5,-9)
