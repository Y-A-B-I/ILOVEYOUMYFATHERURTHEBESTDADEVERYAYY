-- =====================
-- SAVE / LOAD
-- =====================
local SAVE_FILE      = "mwalk_config.json"
local PROFILES_FILE  = "mwalk_profiles.json"

local function deepCopy(t)
    local c = {}
    for k,v in pairs(t) do c[k] = v end
    return c
end

local function jsonSave(file, data)
    if typeof(writefile) == "function" then
        pcall(function() writefile(file, HttpService:JSONEncode(data)) end)
    end
end

local function jsonLoad(file)
    if typeof(readfile) == "function" then
        local ok2, data = pcall(readfile, file)
        if ok2 and data and data ~= "" then
            local ok3, decoded = pcall(function() return HttpService:JSONDecode(data) end)
            if ok3 then return decoded end
        end
    end
    return nil
end

local function loadConfig()
    local decoded = jsonLoad(SAVE_FILE)
    if decoded and typeof(decoded) == "table" then
        local merged = deepCopy(DEFAULTS)
        for k,v in pairs(decoded) do
            if merged[k] ~= nil and typeof(v) == typeof(merged[k]) then
                merged[k] = v
            end
        end
        return merged
    end
    return deepCopy(DEFAULTS)
end

local function loadProfiles()
    local data = jsonLoad(PROFILES_FILE)
    if data and typeof(data) == "table" then return data end
    return {}
end

local Cfg      = loadConfig()
local profiles = loadProfiles()

local function saveConfig()
    jsonSave(SAVE_FILE, Cfg)
end

local function saveProfiles()
    jsonSave(PROFILES_FILE, profiles)
end

local function autoSave()
    if Cfg.AUTO_SAVE then saveConfig() end
end

