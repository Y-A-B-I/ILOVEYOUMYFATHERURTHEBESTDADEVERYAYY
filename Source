        end
        listeningKeybind=idx; kbBtn.Text="..."; kbBtn.TextColor3=Color3.fromRGB(255,210,60)
        TweenService:Create(kbs,TweenInfo.new(0.15),{Color=Color3.fromRGB(255,210,60)}):Play()
    end)
end

