local loaderFlashThread = nil
local function flashLoaderStatus(msg, color)
    loaderStatusLbl.Text = msg; loaderStatusLbl.TextColor3 = color
    if loaderFlashThread then task.cancel(loaderFlashThread) end
    loaderFlashThread = task.delay(2.5, function() loaderStatusLbl.Text = "" end)
