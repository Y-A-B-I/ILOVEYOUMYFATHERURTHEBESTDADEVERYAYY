-- =====================
-- HOLD TIMER LOOP
-- =====================
RunService.Heartbeat:Connect(function(dt)
    if not isHolding or dragging then return end
    holdTimer = holdTimer + dt
    if progressBar then progressBar.Size = UDim2.new(math.clamp(holdTimer/LOCK_HOLD_TIME,0,1),0,1,0) end
    if holdTimer >= LOCK_HOLD_TIME then
        isLocked = not isLocked; cancelHold(); refreshUI()
    end
end)

-- =====================
-- MAIN LOOP
-- =====================
RunService.RenderStepped:Connect(function(dt)
    if not moonwalkActive then return end
    local hrp = getHRP(); local hum = getHum()
    if not hrp or not hum or hum.Health <= 0 then return end

    if hum.WalkSpeed ~= Cfg.MOONWALK_SPEED then hum.WalkSpeed = Cfg.MOONWALK_SPEED end

    stepTimer+=dt; elapsedTime+=dt
    if stepTimer >= Cfg.STEP_INTERVAL then stepTimer=0; stepSide=-stepSide end

    local camLook = camera.CFrame.LookVector
    local targetFwd = Vector3.new(camLook.X,0,camLook.Z)
    if targetFwd.Magnitude > 0.01 then currentFwd = currentFwd:Lerp(targetFwd.Unit, Cfg.TURN_LERP) end
    local fwd = currentFwd.Magnitude > 0.01 and currentFwd.Unit or targetFwd.Unit
    local rightVec = Vector3.new(fwd.Z,0,-fwd.X)
    local sineVal = math.sin(elapsedTime/(Cfg.STEP_INTERVAL*2)*2*math.pi)

    local vel, faceFwd
    if Cfg.FRONT_FACING then
        vel = fwd * Cfg.MOONWALK_SPEED + rightVec * sineVal * Cfg.SWING_WIDTH
        faceFwd = -fwd
    else
        vel = -fwd * Cfg.MOONWALK_SPEED + rightVec * sineVal * Cfg.SWING_WIDTH
        faceFwd = fwd
    end

    hrp.AssemblyLinearVelocity = hrp.AssemblyLinearVelocity:Lerp(
        Vector3.new(vel.X, hrp.AssemblyLinearVelocity.Y, vel.Z), Cfg.LERP_FACTOR)

    local faceCF = CFrame.new(hrp.Position, hrp.Position + faceFwd)
    hrp.CFrame = CFrame.new(hrp.Position)
        * CFrame.fromMatrix(Vector3.new(), faceCF.RightVector, faceCF.UpVector)
        * CFrame.Angles(0, math.rad(sineVal*Cfg.MAX_YAW), 0)
end)

