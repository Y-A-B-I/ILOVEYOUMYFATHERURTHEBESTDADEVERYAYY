local function makeIcon(parent, assetId, fallbackText, size, pos, zindex, color)
    local holder = Instance.new("Frame")
    holder.Size = size; holder.Position = pos
    holder.BackgroundTransparency = 1
    holder.ZIndex = zindex; holder.Parent = parent

    local img = Instance.new("ImageLabel")
    img.Size = UDim2.new(1,0,1,0); img.BackgroundTransparency = 1
    img.Image = assetId; img.ImageColor3 = color or Color3.fromRGB(255,255,255)
    img.ScaleType = Enum.ScaleType.Fit
    img.ZIndex = zindex+1; img.Parent = holder

    local fallback = Instance.new("TextLabel")
    fallback.Size = UDim2.new(1,0,1,0); fallback.BackgroundTransparency = 1
    fallback.Text = fallbackText; fallback.TextColor3 = color or Color3.fromRGB(255,255,255)
    fallback.TextScaled = true; fallback.Font = Enum.Font.GothamBold
    fallback.ZIndex = zindex; fallback.Visible = false; fallback.Parent = holder

    task.spawn(function()
        task.wait(3)
        if not img.IsLoaded or img.ImageRectSize == Vector2.new(0,0) then
            img.Visible = false; fallback.Visible = true
        end
    end)
    img:GetPropertyChangedSignal("IsLoaded"):Connect(function()
        if img.IsLoaded then img.Visible = true; fallback.Visible = false end
    end)
    return holder, img, fallback
end

