    if wallCooldown>0 then wallCooldown=wallCooldown-dt end
end)

-- =====================
-- RENDER STEPPED
-- =====================
RunService.RenderStepped:Connect(function(dt)
    local hrp=getHRP(); local hum=getHum()

    -- Minimap
    if Cfg.SHOW_MINIMAP and hrp then
        local camY=camera.CFrame.LookVector
        local camFwd=Vector3.new(camY.X,0,camY.Z)
        if camFwd.Magnitude<0.01 then camFwd=Vector3.new(0,0,-1) end
        camFwd=camFwd.Unit
        local camRight=Vector3.new(camFwd.Z,0,-camFwd.X)

        if moonwalkActive then
            local moveFwd=Cfg.FRONT_FACING and currentFwd or -currentFwd
            local sx=moveFwd:Dot(camRight); local sz=moveFwd:Dot(camFwd)
            dirArrow.Rotation=math.deg(math.atan2(sx,-sz)); dirArrow.Visible=true
        else
            dirArrow.Visible=false
        end

        for i=1,MINIMAP_DIRS do
            local angle=(i-1)*(2*math.pi/MINIMAP_DIRS)
            local wx=math.sin(angle); local wz=math.cos(angle)
            local worldDir=camRight*wx+camFwd*(-wz)
            worldDir=Vector3.new(worldDir.X,0,worldDir.Z)
            if worldDir.Magnitude<0.01 then wallBlips[i].Visible=false; continue end
            worldDir=worldDir.Unit
            local rayResult=workspace:Raycast(hrp.Position+Vector3.new(0,1,0),worldDir*MINIMAP_RADIUS,wallRayParams)
            local blip=wallBlips[i]
            if rayResult then
                local dist=rayResult.Distance; local t=math.clamp(dist/MINIMAP_RADIUS,0,1)
                blip.Position=UDim2.new(0,mmCX+math.sin(angle)*(t*mmDrawR),0,mmCY+(-math.cos(angle))*(t*mmDrawR))
                if dist<MINIMAP_RADIUS*0.25 then
                    blip.BackgroundColor3=Color3.fromRGB(255,60,60); blip.Size=UDim2.new(0,5,0,5)
                elseif dist<MINIMAP_RADIUS*0.6 then
                    blip.BackgroundColor3=Color3.fromRGB(255,200,60); blip.Size=UDim2.new(0,4,0,4)
                else
                    blip.BackgroundColor3=Color3.fromRGB(60,200,100); blip.Size=UDim2.new(0,3,0,3)
                end
                blip.Visible=true
            else
                blip.Visible=false
            end
        end
    else
        for _,b in ipairs(wallBlips) do b.Visible=false end
        dirArrow.Visible=false
    end

    if smoothAlpha<0.01 then return end
    if not hrp or not hum or hum.Health<=0 then return end

    if hum.WalkSpeed~=Cfg.MOONWALK_SPEED then hum.WalkSpeed=Cfg.MOONWALK_SPEED end

    stepTimer+=dt; elapsedTime+=dt
    if stepTimer>=Cfg.STEP_INTERVAL then stepTimer=0; stepSide=-stepSide end

    local camLook=camera.CFrame.LookVector
    local targetFwd=Vector3.new(camLook.X,0,camLook.Z)
    if targetFwd.Magnitude>0.01 then currentFwd=currentFwd:Lerp(targetFwd.Unit,Cfg.TURN_LERP) end
    local fwd=currentFwd.Magnitude>0.01 and currentFwd.Unit or targetFwd.Unit

    -- Humanized turning
    if Cfg.HUMANIZE_TURNING then
        local noise=Vector3.new(
            math.sin(elapsedTime*1.37+0.63)*Cfg.TURN_NOISE,0,
            math.cos(elapsedTime*0.89+1.21)*Cfg.TURN_NOISE
        )
        local nf=fwd+noise; if nf.Magnitude>0.01 then fwd=nf.Unit end
    end

    -- Anti-detect
    if Cfg.ANTI_DETECT then
        antiTimer+=dt
        if antiTimer>=math.random(20,45)*0.1 then
            antiTimer=0
            antiOffset.speed=math.random(-8,8)*0.1
            antiOffset.swing=math.random(-5,5)*0.1
            antiOffset.yaw=math.random(-4,4)*1.0
        end
    else
        antiOffset={speed=0,swing=0,yaw=0}
    end

    -- Humanized speed
    local effectiveSpeed
    if Cfg.HUMANIZE_SPEED then
        humanSpeedTimer+=dt
        if humanSpeedTimer>=math.random(15,40)*0.1 then
            humanSpeedTimer=0; humanSpeedPhase=(humanSpeedPhase%3)+1
            humanSpeedTarget=({Cfg.SPEED_1,Cfg.SPEED_2,Cfg.SPEED_3})[humanSpeedPhase]
        end
        humanSpeedCurrent=humanSpeedCurrent+(humanSpeedTarget-humanSpeedCurrent)*math.min(dt*1.5,1)
        effectiveSpeed=humanSpeedCurrent+antiOffset.speed
    else
        effectiveSpeed=Cfg.MOONWALK_SPEED+antiOffset.speed
    end

    local effectiveSwing=Cfg.SWING_WIDTH+antiOffset.swing
    local effectiveYaw=Cfg.MAX_YAW+antiOffset.yaw

    -- Wall auto-off — pakai Cfg.WALL_DISTANCE
    if Cfg.WALL_AUTO_OFF and moonwalkActive and wallCooldown<=0 then
        local moveDir=Cfg.FRONT_FACING and fwd or -fwd
        local rayResult=workspace:Raycast(
            hrp.Position+Vector3.new(0,1,0),
            moveDir*Cfg.WALL_DISTANCE,   -- ← configurable
            wallRayParams
        )
        if rayResult then
            moonwalkActive=false; smoothAlpha=0; wallCooldown=1.5
            applyToCharacter(); refreshUI()
            showToast("Wall hit — Moonwalk OFF","warning"); return
        end
    end

    local rightVec=Vector3.new(fwd.Z,0,-fwd.X)
    local sineVal=math.sin(elapsedTime/(Cfg.STEP_INTERVAL*2)*2*math.pi)
    local sideVel=rightVec*sineVal*effectiveSwing
    local moveVel=Cfg.FRONT_FACING and fwd*effectiveSpeed or -fwd*effectiveSpeed

    local targetVel=Vector3.new(
        moveVel.X+sideVel.X,
        hrp.AssemblyLinearVelocity.Y,
        moveVel.Z+sideVel.Z
    )

    -- Apply smooth alpha + Cfg.VEL_SMOOTH
    local scaledVel=Vector3.new(
        targetVel.X*smoothAlpha,
        hrp.AssemblyLinearVelocity.Y,
        targetVel.Z*smoothAlpha
    )
    hrp.AssemblyLinearVelocity=hrp.AssemblyLinearVelocity:Lerp(scaledVel, Cfg.VEL_SMOOTH)  -- ← configurable

    local faceFwd=Cfg.FRONT_FACING and -fwd or fwd
    local faceCF=CFrame.new(hrp.Position,hrp.Position+faceFwd)
    hrp.CFrame=CFrame.new(hrp.Position)
        *CFrame.fromMatrix(Vector3.new(),faceCF.RightVector,faceCF.UpVector)
        *CFrame.Angles(0,math.rad(sineVal*effectiveYaw),0)
end)

refreshUI()
print("🌙 Moonwalk v5.1 | "..Cfg.KEYBIND_1.."/"..Cfg.KEYBIND_2.." | Hold 0.8s = Lock")
showToast("🌙 Violence District loaded","success")

end)
if not ok then warn("🌙 Moonwalk error: "..tostring(err)) end
