    local nameLbl = Instance.new("TextLabel")
    nameLbl.Size = UDim2.new(1,-70,0,14); nameLbl.Position = UDim2.new(0,8,0,4)
    nameLbl.BackgroundTransparency = 1; nameLbl.Text = label
    nameLbl.TextColor3 = Color3.fromRGB(180,200,255); nameLbl.TextSize = 10
    nameLbl.Font = Enum.Font.Gotham; nameLbl.TextXAlignment = Enum.TextXAlignment.Left
    nameLbl.ZIndex = 23; nameLbl.Parent = row

    local inputBox = Instance.new("TextBox")
    inputBox.Size = UDim2.new(0,52,0,16); inputBox.Position = UDim2.new(1,-58,0,2)
    inputBox.BackgroundColor3 = Color3.fromRGB(20,20,45); inputBox.BorderSizePixel = 0
    inputBox.Text = ""; inputBox.TextColor3 = Color3.fromRGB(70,225,255)
    inputBox.PlaceholderText = "0"; inputBox.PlaceholderColor3 = Color3.fromRGB(60,80,100)
    inputBox.TextSize = 10; inputBox.Font = Enum.Font.GothamBold
    inputBox.TextXAlignment = Enum.TextXAlignment.Center
    inputBox.ClearTextOnFocus = false; inputBox.ZIndex = 24; inputBox.Parent = row
    Instance.new("UICorner", inputBox).CornerRadius = UDim.new(0,4)

    local ibStroke = Instance.new("UIStroke")
    ibStroke.Color = Color3.fromRGB(50,70,160); ibStroke.Thickness = 1; ibStroke.Parent = inputBox

    local trackBg = Instance.new("Frame")
    trackBg.Size = UDim2.new(1,-16,0,6); trackBg.Position = UDim2.new(0,8,0,38)
    trackBg.BackgroundColor3 = Color3.fromRGB(25,25,55); trackBg.BorderSizePixel = 0
    trackBg.ZIndex = 23; trackBg.Parent = row
    Instance.new("UICorner", trackBg).CornerRadius = UDim.new(0,3)

    local trackFill = Instance.new("Frame")
    trackFill.Size = UDim2.new(0,0,1,0); trackFill.BackgroundColor3 = Color3.fromRGB(70,150,255)
    trackFill.BorderSizePixel = 0; trackFill.ZIndex = 24; trackFill.Parent = trackBg
    Instance.new("UICorner", trackFill).CornerRadius = UDim.new(0,3)

    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0,10,0,10); thumb.AnchorPoint = Vector2.new(0.5,0.5)
    thumb.BackgroundColor3 = Color3.fromRGB(255,255,255); thumb.BorderSizePixel = 0
    thumb.ZIndex = 25; thumb.Parent = trackBg
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1,0)

    local function applyValue(val)
        val = math.clamp(val, minVal, maxVal)
        local mult = 10^decimals; val = math.floor(val*mult+0.5)/mult
        local t = (val-minVal)/(maxVal-minVal)
        trackFill.Size = UDim2.new(t,0,1,0); thumb.Position = UDim2.new(t,0,0.5,0)
        inputBox.Text = string.format(fmt,val); Cfg[key] = val
        ibStroke.Color = Color3.fromRGB(50,70,160); autoSave()
    end

    applyValue(Cfg[key]); sliderUpdaters[key] = applyValue

    local drag = false
    trackBg.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
            drag = true
            applyValue(minVal+(maxVal-minVal)*math.clamp((inp.Position.X-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X,0,1))
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if not drag then return end
        if inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch then
            applyValue(minVal+(maxVal-minVal)*math.clamp((inp.Position.X-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X,0,1))
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then drag=false end
    end)

    inputBox.Focused:Connect(function() ibStroke.Color=Color3.fromRGB(70,150,255) end)
    inputBox:GetPropertyChangedSignal("Text"):Connect(function()
        local c = inputBox.Text:match("^%-?%d*%.?%d*") or ""
        if c~=inputBox.Text then inputBox.Text=c end
    end)
    inputBox.FocusLost:Connect(function()
        local n = tonumber(inputBox.Text)
        if n then applyValue(n)
        else inputBox.Text=string.format(fmt,Cfg[key]); ibStroke.Color=Color3.fromRGB(160,50,50)
            task.delay(1,function() ibStroke.Color=Color3.fromRGB(50,70,160) end) end
    end)
end

