    lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.ZIndex=23; lbl.Parent=row

    local kbBtn=Instance.new("TextButton"); kbBtn.Size=UDim2.new(0,52,0,22)
    kbBtn.Position=UDim2.new(1,-58,0.5,-11); kbBtn.BackgroundColor3=Color3.fromRGB(20,20,45)
