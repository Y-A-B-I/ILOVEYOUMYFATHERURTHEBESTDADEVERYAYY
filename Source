local function applyToCharacter()
    local hum = getHum(); if not hum then return end
    if moonwalkActive then
        savedWalkSpeed = hum.WalkSpeed
        local s = Vector3.new(camera.CFrame.LookVector.X, 0, camera.CFrame.LookVector.Z)
        if s.Magnitude > 0.01 then currentFwd = s.Unit end
    end
    hum.AutoRotate = not moonwalkActive
    hum.WalkSpeed  = moonwalkActive and Cfg.MOONWALK_SPEED or savedWalkSpeed
end

-- =====================
-- DRAG + HOLD LOGIC (shared for both frames)
-- =====================
local progressBar  -- active progress bar reference
local dragging, dragStart, startPos = false, nil, nil

local function cancelHold()
    isHolding = false; holdTimer = 0
    if progressBar then progressBar.Size = UDim2.new(0,0,1,0) end
end

local function handleInputBegan(inp, progBar)
    if inp.UserInputType ~= Enum.UserInputType.Touch
    and inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
    if activeInput ~= nil then return end
    activeInput = inp; isHolding = true; holdTimer = 0
    dragStart = inp.Position; startPos = getActiveFrame().Position
    dragging = false; tapConsumed = false; progressBar = progBar
end

rectTapBtn.InputBegan:Connect(function(inp) handleInputBegan(inp, rectProgBar) end)
boxTapBtn.InputBegan:Connect(function(inp) handleInputBegan(inp, boxProgBar) end)

UserInputService.InputChanged:Connect(function(inp)
    if inp ~= activeInput then return end
    if not isHolding then return end
    local d = inp.Position - dragStart
    local dist = math.sqrt(d.X^2+d.Y^2)
    if dist > DRAG_THRESHOLD then
        if not dragging then
            dragging = true; holdTimer = 0
            if progressBar then progressBar.Size = UDim2.new(0,0,1,0) end
        end
    end
    if dragging and not isLocked then
        local af = getActiveFrame()
        af.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)
        if cfgPanel.Visible then
            cfgPanel.Position = UDim2.new(af.Position.X.Scale, af.Position.X.Offset-67, af.Position.Y.Scale, af.Position.Y.Offset-430)
        end
    end
end)

UserInputService.InputEnded:Connect(function(inp)
    if inp ~= activeInput then return end
    local wasDragging = dragging; local heldTime = holdTimer
    dragging = false; activeInput = nil; cancelHold()
    if not tapConsumed and not wasDragging and heldTime < LOCK_HOLD_TIME then
        tapConsumed = true
        moonwalkActive = not moonwalkActive
        stepTimer=0; stepSide=1; elapsedTime=0
        applyToCharacter(); refreshUI()
    end
end)

-- =====================
-- KEYBOARD TOGGLE + KEYBIND LISTEN
-- =====================
UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end

    -- Keybind capture mode
    if listeningKeybind then
        if inp.UserInputType == Enum.UserInputType.Keyboard then
            local keyName = inp.KeyCode.Name
            local kbData = keybindBtns[listeningKeybind]
            if kbData then
                Cfg[kbData.cfgKey] = keyName
                kbData.btn.Text = keyName
                kbData.btn.TextColor3 = Color3.fromRGB(70,225,255)
                TweenService:Create(kbData.stroke,TweenInfo.new(0.15),{Color=Color3.fromRGB(50,70,160)}):Play()
            end
            listeningKeybind = nil
            autoSave()
            return
        end
    end

    -- Normal toggle
    if inp.UserInputType == Enum.UserInputType.Keyboard then
        local keyName = inp.KeyCode.Name
        if keyName == Cfg.KEYBIND_1 or keyName == Cfg.KEYBIND_2 then
            moonwalkActive = not moonwalkActive
            stepTimer=0; stepSide=1; elapsedTime=0
            applyToCharacter(); refreshUI()
        end
    end
end)

