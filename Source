local toastQueue   = {}
local toastRunning = false

local function showToast(msg, toastType)
    table.insert(toastQueue, {msg=msg, type=toastType or "info"})
    if toastRunning then return end
    toastRunning = true
    task.spawn(function()
        while #toastQueue > 0 do
            local item = table.remove(toastQueue, 1)
            local cmap = {
                info    = {Color3.fromRGB(20,20,45),   Color3.fromRGB(100,160,255), Color3.fromRGB(50,80,180)  },
                success = {Color3.fromRGB(10,35,15),   Color3.fromRGB(80,220,120),  Color3.fromRGB(30,120,50)  },
                warning = {Color3.fromRGB(40,30,5),    Color3.fromRGB(255,200,60),  Color3.fromRGB(160,120,20) },
                error   = {Color3.fromRGB(40,10,10),   Color3.fromRGB(255,80,80),   Color3.fromRGB(160,30,30)  },
            }
            local c = cmap[item.type] or cmap.info

            local toast = Instance.new("Frame")
            toast.Size=UDim2.new(0,220,0,34); toast.AnchorPoint=Vector2.new(0.5,0)
            toast.Position=UDim2.new(0.5,0,0,-44)
            toast.BackgroundColor3=c[1]; toast.BackgroundTransparency=0.08
            toast.BorderSizePixel=0; toast.ZIndex=500; toast.Parent=gui
            Instance.new("UICorner",toast).CornerRadius=UDim.new(0,8)
            local ts=Instance.new("UIStroke"); ts.Color=c[3]; ts.Thickness=1; ts.Parent=toast

            local bar=Instance.new("Frame")
            bar.Size=UDim2.new(0,3,1,-10); bar.Position=UDim2.new(0,4,0,5)
            bar.BackgroundColor3=c[2]; bar.BorderSizePixel=0; bar.ZIndex=501; bar.Parent=toast
            Instance.new("UICorner",bar).CornerRadius=UDim.new(1,0)

            local tl=Instance.new("TextLabel")
            tl.Size=UDim2.new(1,-16,1,0); tl.Position=UDim2.new(0,13,0,0)
            tl.BackgroundTransparency=1; tl.Text=msg; tl.TextColor3=c[2]
            tl.TextSize=10; tl.Font=Enum.Font.GothamBold
            tl.TextXAlignment=Enum.TextXAlignment.Left
            tl.TextWrapped=true; tl.ZIndex=501; tl.Parent=toast

            TweenService:Create(toast,TweenInfo.new(0.3,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),
                {Position=UDim2.new(0.5,0,0,10)}):Play()
            task.wait(2.2)
            TweenService:Create(toast,TweenInfo.new(0.25,Enum.EasingStyle.Quint,Enum.EasingDirection.In),
                {Position=UDim2.new(0.5,0,0,-44)}):Play()
            task.wait(0.28); toast:Destroy(); task.wait(0.08)
        end
        toastRunning=false
    end)
end

