        if val then
            TweenService:Create(pill,TweenInfo.new(0.18),{BackgroundColor3=Color3.fromRGB(30,80,180)}):Play()
            TweenService:Create(knob,TweenInfo.new(0.18),{Position=UDim2.new(0,21,0.5,-6),BackgroundColor3=Color3.fromRGB(200,220,255)}):Play()
            TweenService:Create(pillStroke,TweenInfo.new(0.18),{Color=Color3.fromRGB(70,150,255)}):Play()
        else
            TweenService:Create(pill,TweenInfo.new(0.18),{BackgroundColor3=Color3.fromRGB(40,40,80)}):Play()
            TweenService:Create(knob,TweenInfo.new(0.18),{Position=UDim2.new(0,3,0.5,-6),BackgroundColor3=Color3.fromRGB(140,140,180)}):Play()
            TweenService:Create(pillStroke,TweenInfo.new(0.18),{Color=Color3.fromRGB(55,55,120)}):Play()
        end
