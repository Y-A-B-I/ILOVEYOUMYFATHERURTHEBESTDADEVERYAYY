RunService.Heartbeat:Connect(function(dt)
    -- Smooth toggle alpha
    local alphaTarget=moonwalkActive and 1 or 0
    smoothAlpha=smoothAlpha+(alphaTarget-smoothAlpha)*math.min(dt*Cfg.SMOOTH_SPEED,1)

    -- Alert cooldown
    if killerAlertCooldown>0 then killerAlertCooldown=killerAlertCooldown-dt end

    -- Timer moonwalk countdown
    if timerActive and moonwalkActive and Cfg.TIMER_ENABLED then
        timerCountdown=timerCountdown-dt
        local pct=math.clamp(timerCountdown/Cfg.TIMER_DURATION,0,1)
        timerFill.Size=UDim2.new(pct,0,1,0)
        timerLbl.Text="⏱ "..string.format("%.1f",math.max(timerCountdown,0)).."s"

        -- Color shift: green → yellow → red as time runs out
        if pct>0.5 then
            timerFill.BackgroundColor3=Color3.fromRGB(80,200,80)
            timerS.Color=Color3.fromRGB(60,160,60)
        elseif pct>0.25 then
            timerFill.BackgroundColor3=Color3.fromRGB(255,200,40)
            timerS.Color=Color3.fromRGB(180,140,20)
        else
            timerFill.BackgroundColor3=Color3.fromRGB(255,60,60)
            timerS.Color=Color3.fromRGB(180,30,30)
        end

        if timerCountdown<=0 then
            timerActive=false;moonwalkActive=false
            applyToCharacter();refreshUI()
            showToast("Timer ended — Moonwalk OFF","warning",Color3.fromRGB(255,80,80))
        end
    else
        timerIndicator.Visible=(moonwalkActive and Cfg.TIMER_ENABLED)
    end

    -- Hold lock timer
    if isHolding and not dragging then
        holdTimer=holdTimer+dt
        if progressBar then progressBar.Size=UDim2.new(math.clamp(holdTimer/LOCK_HOLD_TIME,0,1),0,1,0) end
        if holdTimer>=LOCK_HOLD_TIME then
            isLocked=not isLocked;cancelHold();refreshUI()
            showToast(isLocked and "Position Locked 🔒" or "Position Unlocked",
                isLocked and "warning" or "info",
                isLocked and Color3.fromRGB(255,200,60) or Color3.fromRGB(100,160,255))
        end
    end

    -- Wall cooldown
    if wallCooldown>0 then wallCooldown=wallCooldown-dt end
end)

-- =====================
