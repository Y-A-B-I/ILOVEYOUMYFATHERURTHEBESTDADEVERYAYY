    cfgSaveLbl.Text = msg; cfgSaveLbl.TextColor3 = color
    if saveFlashThread then task.cancel(saveFlashThread) end
    saveFlashThread = task.delay(2.5, function() cfgSaveLbl.Text = "" end)
end

saveBtn.MouseButton1Click:Connect(function()
    saveConfig(); flashSaveLabel("Config saved!", Color3.fromRGB(100,255,100))
end)

resetBtn.MouseButton1Click:Connect(function()
    for k,v in pairs(DEFAULTS) do
        Cfg[k] = v
        if sliderUpdaters[k] then sliderUpdaters[k](v) end
        if toggleRefreshers[k] then toggleRefreshers[k](v) end
    end
    Cfg.GUI_MODE_BOX = (Cfg.GUI_MODE == "box")
    if toggleRefreshers["GUI_MODE_BOX"] then toggleRefreshers["GUI_MODE_BOX"](Cfg.GUI_MODE_BOX) end
    rectFrame.Visible = (Cfg.GUI_MODE == "rectangle")
    boxFrame.Visible  = (Cfg.GUI_MODE == "box")
    for _, kb in pairs(keybindBtns) do kb.btn.Text = Cfg[kb.cfgKey] end
    saveConfig(); flashSaveLabel("Reset to defaults!", Color3.fromRGB(255,180,80))
end)

