-- =====================
local dragging,dragStart,startPos=false,nil,nil

local function cancelHold()
    isHolding=false; holdTimer=0
    if progressBar then progressBar.Size=UDim2.new(0,0,1,0) end
end

local function handleInputBegan(inp, progB)
    if inp.UserInputType~=Enum.UserInputType.Touch
    and inp.UserInputType~=Enum.UserInputType.MouseButton1 then return end
    if activeInput~=nil then return end
    activeInput=inp; isHolding=true; holdTimer=0
    dragStart=inp.Position; startPos=getActiveFrame().Position
    dragging=false; tapConsumed=false; progressBar=progB
end

rectTap.InputBegan:Connect(function(inp) handleInputBegan(inp,rectProgBar) end)
boxTap.InputBegan:Connect(function(inp) handleInputBegan(inp,boxProgBar) end)

UserInputService.InputChanged:Connect(function(inp)
    if inp~=activeInput then return end
    if not isHolding then return end
    local d=inp.Position-dragStart
    if math.sqrt(d.X^2+d.Y^2)>DRAG_THRESHOLD then
        if not dragging then
            dragging=true; holdTimer=0
            if progressBar then progressBar.Size=UDim2.new(0,0,1,0) end
        end
    end
    if dragging and not isLocked then
        local af=getActiveFrame()
        af.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
        if cfgPanel.Visible then
            cfgPanel.Position=UDim2.new(af.Position.X.Scale,af.Position.X.Offset-67,
                af.Position.Y.Scale,af.Position.Y.Offset-410)
        end
    end
end)

UserInputService.InputEnded:Connect(function(inp)
    if inp~=activeInput then return end
    local wd=dragging; local ht=holdTimer
    dragging=false; activeInput=nil; cancelHold()
    if not tapConsumed and not wd and ht<LOCK_HOLD_TIME then
        tapConsumed=true; moonwalkActive=not moonwalkActive
        stepTimer=0; stepSide=1; elapsedTime=0
        humanSpeedCurrent=Cfg.MOONWALK_SPEED; humanSpeedTarget=Cfg.MOONWALK_SPEED
        applyToCharacter(); refreshUI()
        showToast("Moonwalk "..(moonwalkActive and "ON" or "OFF"), moonwalkActive and "success" or "info")
    end
end)

