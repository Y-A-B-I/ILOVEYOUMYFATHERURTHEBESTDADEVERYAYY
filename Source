-- =====================
-- SAVE / LOAD
-- =====================
local SAVE_FILE     = "mwalk_config.json"
local PROFILES_FILE = "mwalk_profiles.json"

local function deepCopy(t)
    local c={}; for k,v in pairs(t) do c[k]=v end; return c
end

local function jsonSave(file, data)
    if typeof(writefile)=="function" then
        pcall(function() writefile(file, HttpService:JSONEncode(data)) end)
    end
end

local function jsonLoad(file)
    if typeof(readfile)=="function" then
        local ok2,data = pcall(readfile, file)
        if ok2 and data and data~="" then
            local ok3,dec = pcall(function() return HttpService:JSONDecode(data) end)
            if ok3 then return dec end
        end
    end
    return nil
end

local function loadConfig()
    local dec = jsonLoad(SAVE_FILE)
    if dec and typeof(dec)=="table" then
        local m = deepCopy(DEFAULTS)
        for k,v in pairs(dec) do
            if m[k]~=nil and typeof(v)==typeof(m[k]) then m[k]=v end
        end
        return m
    end
    return deepCopy(DEFAULTS)
end

local Cfg      = loadConfig()
local profiles = jsonLoad(PROFILES_FILE) or {}

local function saveConfig()   jsonSave(SAVE_FILE, Cfg)         end
local function saveProfiles() jsonSave(PROFILES_FILE, profiles) end
local function autoSave()     if Cfg.AUTO_SAVE then saveConfig() end end

