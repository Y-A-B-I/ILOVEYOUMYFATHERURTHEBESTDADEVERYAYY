-- Get toast start/end position based on config
local function getToastPositions()
    local pos = Cfg and Cfg.TOAST_POSITION or "default"
    if pos == "top_left" then
        return UDim2.new(0,-235,0,10), UDim2.new(0,10,0,10),
               UDim2.new(0,-235,0,10)  -- exit same direction
    elseif pos == "bottom_left" then
        return UDim2.new(0,-235,1,-44), UDim2.new(0,10,1,-44),
               UDim2.new(0,-235,1,-44)
    else -- default top center
        return UDim2.new(0.5,-110,0,-44), UDim2.new(0.5,-110,0,10),
               UDim2.new(0.5,-110,0,-44)
    end
end

-- pulseColor: Color3 for pulsing ring, nil = no pulse
local function showToast(msg, toastType, pulseColor)
    table.insert(toastQueue,{msg=msg,type=toastType or "info",pulse=pulseColor})
    if toastRunning then return end
    toastRunning=true
    task.spawn(function()
        while #toastQueue>0 do
            local item=table.remove(toastQueue,1)
            local cmap={
                info    ={Color3.fromRGB(18,18,40),  Color3.fromRGB(100,160,255),Color3.fromRGB(50,80,180)  },
                success ={Color3.fromRGB(8,28,12),   Color3.fromRGB(80,220,120), Color3.fromRGB(30,120,50)  },
                warning ={Color3.fromRGB(35,25,4),   Color3.fromRGB(255,200,60), Color3.fromRGB(160,120,20) },
                error   ={Color3.fromRGB(35,8,8),    Color3.fromRGB(255,80,80),  Color3.fromRGB(160,30,30)  },
            }
            local c=cmap[item.type] or cmap.info
            local startP,endP,exitP=getToastPositions()

            -- Toast frame
            local toast=Instance.new("Frame")
            toast.Size=UDim2.new(0,220,0,36)
            toast.AnchorPoint=Vector2.new(0,0)
            toast.Position=startP
            toast.BackgroundColor3=c[1]
            toast.BackgroundTransparency=0.06
            toast.BorderSizePixel=0;toast.ZIndex=500;toast.Parent=gui
            Instance.new("UICorner",toast).CornerRadius=UDim.new(0,9)
            local ts=Instance.new("UIStroke");ts.Color=c[3];ts.Thickness=1;ts.Parent=toast

            -- ── Pulse ring (if pulseColor provided) ──
            if item.pulse then
                local ringHolder=Instance.new("Frame")
                ringHolder.Size=UDim2.new(0,36,0,36)
                ringHolder.Position=UDim2.new(0,0,0,0)
                ringHolder.BackgroundTransparency=1
                ringHolder.ZIndex=501;ringHolder.Parent=toast

                -- Outer pulse ring
                local ring=Instance.new("Frame")
                ring.Size=UDim2.new(0,20,0,20)
                ring.AnchorPoint=Vector2.new(0.5,0.5)
                ring.Position=UDim2.new(0.5,0,0.5,0)
                ring.BackgroundColor3=item.pulse
                ring.BackgroundTransparency=0.35
                ring.BorderSizePixel=0;ring.ZIndex=502;ring.Parent=ringHolder
                Instance.new("UICorner",ring).CornerRadius=UDim.new(1,0)

                -- Inner dot
                local dot=Instance.new("Frame")
                dot.Size=UDim2.new(0,8,0,8)
                dot.AnchorPoint=Vector2.new(0.5,0.5)
                dot.Position=UDim2.new(0.5,0,0.5,0)
                dot.BackgroundColor3=item.pulse
                dot.BorderSizePixel=0;dot.ZIndex=503;dot.Parent=ring
                Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0)

                -- Pulse loop
                local pulsing=true
                task.spawn(function()
                    while pulsing and ring.Parent do
                        ring.Size=UDim2.new(0,20,0,20)
                        ring.BackgroundTransparency=0.35
                        TweenService:Create(ring,TweenInfo.new(0.55,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{
                            Size=UDim2.new(0,36,0,36),
                            BackgroundTransparency=1
                        }):Play()
                        task.wait(0.65)
                    end
                end)

                -- Text offset for pulse
                local tl=Instance.new("TextLabel")
                tl.Size=UDim2.new(1,-46,1,0);tl.Position=UDim2.new(0,40,0,0)
                tl.BackgroundTransparency=1;tl.Text=item.msg;tl.TextColor3=c[2]
                tl.TextSize=10;tl.Font=Enum.Font.GothamBold
                tl.TextXAlignment=Enum.TextXAlignment.Left
                tl.TextWrapped=true;tl.ZIndex=501;tl.Parent=toast

                task.delay(2.4,function() pulsing=false end)
            else
                -- Standard left bar (no pulse)
                local bar=Instance.new("Frame")
                bar.Size=UDim2.new(0,3,1,-10);bar.Position=UDim2.new(0,4,0,5)
                bar.BackgroundColor3=c[2];bar.BorderSizePixel=0;bar.ZIndex=501;bar.Parent=toast
                Instance.new("UICorner",bar).CornerRadius=UDim.new(1,0)

                local tl=Instance.new("TextLabel")
                tl.Size=UDim2.new(1,-16,1,0);tl.Position=UDim2.new(0,13,0,0)
                tl.BackgroundTransparency=1;tl.Text=item.msg;tl.TextColor3=c[2]
                tl.TextSize=10;tl.Font=Enum.Font.GothamBold
                tl.TextXAlignment=Enum.TextXAlignment.Left
                tl.TextWrapped=true;tl.ZIndex=501;tl.Parent=toast
            end

            -- Slide in
            local slideIn=TweenInfo.new(0.32,Enum.EasingStyle.Quint,Enum.EasingDirection.Out)
            TweenService:Create(toast,slideIn,{Position=endP}):Play()
            task.wait(2.3)

            -- Slide out
            TweenService:Create(toast,TweenInfo.new(0.25,Enum.EasingStyle.Quint,Enum.EasingDirection.In),
                {Position=exitP}):Play()
            task.wait(0.28);toast:Destroy();task.wait(0.08)
        end
        toastRunning=false
    end)
end

