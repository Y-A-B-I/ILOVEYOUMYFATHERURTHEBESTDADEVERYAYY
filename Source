local sliderUpdaters = {}

local function makeSlider(label, key, minVal, maxVal, decimals, layoutOrder)
    local fmt = decimals > 0 and ("%."..decimals.."f") or "%d"
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,0,0,56); row.BackgroundColor3 = Color3.fromRGB(13,13,28)
    row.BorderSizePixel = 0; row.LayoutOrder = layoutOrder; row.ZIndex = 22; row.Parent = contentFrame
