    Instance.new("UICorner",pill).CornerRadius=UDim.new(1,0)
    local ps=Instance.new("UIStroke");ps.Color=Color3.fromRGB(55,55,120);ps.Thickness=1;ps.Parent=pill
    local knob=Instance.new("Frame");knob.Size=UDim2.new(0,12,0,12);knob.Position=UDim2.new(0,3,0.5,-6)
    knob.BackgroundColor3=Color3.fromRGB(140,140,180);knob.BorderSizePixel=0;knob.ZIndex=24;knob.Parent=pill
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)
    local pb=Instance.new("TextButton");pb.Size=UDim2.new(1,0,1,0);pb.BackgroundTransparency=1;pb.Text="";pb.ZIndex=25;pb.Parent=pill
    local function refresh(val)
        local t=getTheme()
        if val then
            TweenService:Create(pill,TweenInfo.new(0.18),{BackgroundColor3=Color3.fromRGB(20,60,160)}):Play()
            TweenService:Create(knob,TweenInfo.new(0.18),{Position=UDim2.new(0,21,0.5,-6),BackgroundColor3=t.accent}):Play()
            TweenService:Create(ps,TweenInfo.new(0.18),{Color=t.stroke}):Play()
        else
            TweenService:Create(pill,TweenInfo.new(0.18),{BackgroundColor3=Color3.fromRGB(40,40,80)}):Play()
            TweenService:Create(knob,TweenInfo.new(0.18),{Position=UDim2.new(0,3,0.5,-6),BackgroundColor3=Color3.fromRGB(140,140,180)}):Play()
            TweenService:Create(ps,TweenInfo.new(0.18),{Color=Color3.fromRGB(55,55,120)}):Play()
        end
    end
    refresh(Cfg[key]);toggleRefreshers[key]=refresh
    pb.MouseButton1Click:Connect(function()
        Cfg[key]=not Cfg[key];refresh(Cfg[key]);autoSave()
        -- ← Auto notify with pulse for every toggle
        local isOn=Cfg[key]
        local pulseCol=isOn and Color3.fromRGB(80,220,120) or Color3.fromRGB(255,80,80)
        local toastT=isOn and "success" or "info"
        showToast(label..": "..(isOn and "ON" or "OFF"), toastT, pulseCol)
        if onToggle then onToggle(Cfg[key]) end
    end)
    return refresh
end

