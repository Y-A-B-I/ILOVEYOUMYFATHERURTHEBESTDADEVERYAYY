local function buildProfiles()
    for _,c in ipairs(profilesList:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
    local names={};for n in pairs(profiles) do table.insert(names,n) end;table.sort(names)
    if #names==0 then
        local el=Instance.new("TextLabel");el.Size=UDim2.new(1,0,0,28);el.BackgroundTransparency=1
        el.Text="No saved configs.";el.TextColor3=Color3.fromRGB(70,80,120);el.TextSize=10
        el.Font=Enum.Font.Gotham;el.ZIndex=32;el.Parent=profilesList;return
    end
    for i,name in ipairs(names) do
        local pr=Instance.new("Frame");pr.Size=UDim2.new(1,0,0,30);pr.BackgroundColor3=Color3.fromRGB(13,13,28)
        pr.BorderSizePixel=0;pr.LayoutOrder=i;pr.ZIndex=32;pr.Parent=profilesList
        Instance.new("UICorner",pr).CornerRadius=UDim.new(0,6)
        local nl=Instance.new("TextLabel");nl.Size=UDim2.new(1,-76,1,0);nl.Position=UDim2.new(0,8,0,0)
        nl.BackgroundTransparency=1;nl.Text=name;nl.TextColor3=Color3.fromRGB(180,200,255)
        nl.TextSize=10;nl.Font=Enum.Font.GothamMedium;nl.TextXAlignment=Enum.TextXAlignment.Left
        nl.TextTruncate=Enum.TextTruncate.AtEnd;nl.ZIndex=33;nl.Parent=pr
        local lb=Instance.new("TextButton");lb.Size=UDim2.new(0,32,0,20);lb.Position=UDim2.new(1,-72,0.5,-10)
        lb.BackgroundColor3=Color3.fromRGB(15,50,100);lb.BorderSizePixel=0;lb.Text="Load"
        lb.TextColor3=Color3.fromRGB(100,180,255);lb.TextSize=9;lb.Font=Enum.Font.GothamBold;lb.ZIndex=33;lb.Parent=pr
        Instance.new("UICorner",lb).CornerRadius=UDim.new(0,4)
        local db=Instance.new("TextButton");db.Size=UDim2.new(0,32,0,20);db.Position=UDim2.new(1,-34,0.5,-10)
        db.BackgroundColor3=Color3.fromRGB(80,15,15);db.BorderSizePixel=0;db.Text="Del"
        db.TextColor3=Color3.fromRGB(255,100,100);db.TextSize=9;db.Font=Enum.Font.GothamBold;db.ZIndex=33;db.Parent=pr
        Instance.new("UICorner",db).CornerRadius=UDim.new(0,4)
        local cap=name
        lb.MouseButton1Click:Connect(function()
            local pd=profiles[cap];if not pd then return end
            for k,v in pairs(pd) do
                if Cfg[k]~=nil and typeof(v)==typeof(Cfg[k]) then Cfg[k]=v
                    if sliderUpdaters[k] then sliderUpdaters[k](v) end
                    if toggleRefreshers[k] then toggleRefreshers[k](v) end
                end
            end
            for _,kb in pairs(keybindBtns) do kb.btn.Text=Cfg[kb.cfgKey] end
            rectFrame.Visible=(Cfg.GUI_MODE=="rectangle");boxFrame.Visible=(Cfg.GUI_MODE=="box")
            minimapFrame.Visible=Cfg.SHOW_MINIMAP;saveConfig()
            flashLdr('Loaded "'..cap..'"',Color3.fromRGB(100,255,100))
            showToast('Config "'..cap..'" loaded',"success",Color3.fromRGB(80,220,120))
        end)
        db.MouseButton1Click:Connect(function()
            profiles[cap]=nil;saveProfiles();buildProfiles()
            flashLdr('Deleted "'..cap..'"',Color3.fromRGB(255,160,80))
            showToast('Deleted "'..cap..'"',"warning",Color3.fromRGB(255,160,80))
        end)
    end
end

