-- =====================
-- KILLER PROXIMITY DETECTION LOOP
-- =====================
task.spawn(function()
    while true do
        task.wait(0.5)
        if not Cfg.KILLER_NOTIFY then
            -- Clean up all highlights if disabled
            for p,sb in pairs(killerHighlights) do
                if sb then sb:Destroy() end
                killerHighlights[p]=nil
            end
            continue
        end

        local myHRP=getHRP()
        if not myHRP then continue end

        local currentKillers={}

        for _,p in ipairs(Players:GetPlayers()) do
            if p==player then continue end
            local char=p.Character
            if not char then continue end

            -- Check team name
            local isKiller=false
            if p.Team and p.Team.Name==Cfg.KILLER_TEAM then
                isKiller=true
            end
            -- Also check by name in TeamColor or custom attribute
            if not isKiller and char:FindFirstChild("IsKiller") then
                isKiller=true
            end

            if not isKiller then
                -- Clean highlight if no longer killer
                if killerHighlights[p] then killerHighlights[p]:Destroy();killerHighlights[p]=nil end
                continue
            end

            local killerHRP=char:FindFirstChild("HumanoidRootPart")
            if not killerHRP then continue end

            local dist=(myHRP.Position-killerHRP.Position).Magnitude

            if dist<=Cfg.KILLER_RANGE then
                currentKillers[p]=dist

                -- Highlight
                if Cfg.KILLER_MODE=="highlight" or Cfg.KILLER_MODE=="both" then
                    if not killerHighlights[p] then
                        local sb=Instance.new("SelectionBox")
                        sb.Adornee=char
                        sb.Color3=Color3.fromRGB(255,60,60)
                        sb.LineThickness=0.06
                        sb.SurfaceTransparency=0.7
                        sb.SurfaceColor3=Color3.fromRGB(255,60,60)
                        sb.Parent=workspace
                        killerHighlights[p]=sb
                    end
                end

                -- Notify (with cooldown so it doesn't spam)
                if (Cfg.KILLER_MODE=="notify" or Cfg.KILLER_MODE=="both") and killerAlertCooldown<=0 then
                    local distStr=math.floor(dist).."st"
                    showToast("⚠ "..p.Name.." nearby! ("..distStr..")","error",Color3.fromRGB(255,60,60))
                    killerAlertCooldown=4  -- 4 second cooldown between alerts
                end
            else
                -- Out of range — remove highlight
                if killerHighlights[p] then killerHighlights[p]:Destroy();killerHighlights[p]=nil end
            end
        end

        -- Clean up highlights for players who left
        for p,sb in pairs(killerHighlights) do
            if not currentKillers[p] then
                if sb then sb:Destroy() end
                killerHighlights[p]=nil
            end
        end
    end
end)

